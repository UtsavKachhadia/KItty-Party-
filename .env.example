# ── Server ──────────────────────────────────────────────
PORT=3001                              # Express + Socket.io listen port

# ── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/mcp-gateway?retryWrites=true&w=majority

# ── Upstash Redis (REST API — no driver needed) ────────
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io   # Upstash REST endpoint
UPSTASH_REDIS_REST_TOKEN=AX...                          # Upstash REST token

# ── Groq LLM ───────────────────────────────────────────
GROQ_API_KEY=gsk_...                   # Groq cloud API key

# ── GitHub ──────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                   # GitHub personal access token (repo scope)

# ── Slack ───────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...               # Slack Bot User OAuth token

# ── Jira Cloud ──────────────────────────────────────────
JIRA_BASE_URL=https://harshininimmagadda1609.atlassian.net   # Jira Cloud instance URL
JIRA_EMAIL=harshininimmagadda1609@gmail.com              # Atlassian account email
JIRA_API_TOKEN=ATATT...                # Jira API token

# ── App Auth ────────────────────────────────────────────
APP_API_KEY=hackathon-secret           # Simple API key for request auth
